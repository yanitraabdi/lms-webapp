# Copy to .env and fill in. NEVER commit real secrets. Local dev works with the defaults below.

# ---- Database ----
POSTGRES_USER=academy
POSTGRES_PASSWORD=academy
POSTGRES_DB=academy
# Host port for the compose Postgres. Change if 5432 is already in use locally (e.g. 5433).
POSTGRES_PORT=5432
ConnectionStrings__Default=Host=localhost;Port=5432;Database=academy;Username=academy;Password=academy

# ---- API ----
ASPNETCORE_ENVIRONMENT=Development
RunMigrations=false
Cors__AllowedOrigins__0=http://localhost:3000

# ---- Auth / JWT (M1) ----
Jwt__SigningKey=
Jwt__Issuer=academy
Jwt__Audience=academy

# ---- Google SSO (M1) ----
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# ---- Amazon SES — transactional email (M1) ----
Ses__Region=
Ses__AccessKeyId=
Ses__SecretAccessKey=
Ses__FromAddress=

# ---- Xendit — payments (M3) ----
Xendit__SecretApiKey=
Xendit__WebhookToken=

# ---- Bunny Stream — video (M4) ----
Bunny__ApiKey=
Bunny__LibraryId=
Bunny__SignToken=

# ---- Cloudflare R2 — object storage (M4) ----
R2__AccountId=
R2__AccessKeyId=
R2__SecretAccessKey=
R2__Bucket=

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# Server-side base URL the Next auth BFF uses to reach the API (compose: http://api:8080).
API_INTERNAL_URL=http://localhost:8080
